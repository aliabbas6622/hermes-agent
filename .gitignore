```gitignore
# Dependencies
__pycache__/
*.pyc
*.pyo
*.pyd
*.py.class
*.py.obj

# Database
jarvis_memory.db

# Environment
.env
.env.local
*.env.*

# Logs
*.log

# Temporary files
*.tmp
*.temp
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Coverage reports
.coverage
coverage/
htmlcov/

# Python specific
*.egg-info/
.eggs/
.Python
*.so
*.dylib
*.dll

# Build directories
build/
dist/
*.egg
*.whl
```